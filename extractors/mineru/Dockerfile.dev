# syntax=docker/dockerfile:1.7
#
# mineru-svc — Single-stage dev image for LC Invoice Checker.
# Layer ordering: deps first (cached across code edits), then source.
#
# Pre-warm: models download + initialize during build so startup is instant.
#
# Usage (with HF token for faster downloads):
#   docker build -t lc-checker/mineru:dev \
#        --build-arg HF_TOKEN=hf_xxx \
#        -f extractors/mineru/Dockerfile.dev extractors/mineru
#   docker run --rm -p 8082:8082 \
#        -e HF_TOKEN=hf_xxx \
#        --env-file .env \
#        lc-checker/mineru:dev
#
# Usage (no token — models downloaded anonymously, slower first run):
#   docker build -t lc-checker/mineru:dev -f extractors/mineru/Dockerfile.dev extractors/mineru
#   docker run --rm -p 8082:8082 --env-file .env lc-checker/mineru:dev

FROM python:3.12-slim

ARG HF_TOKEN=

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        poppler-utils \
        libmagic1 \
        libgl1 \
        libglib2.0-0 \
        libxext6 \
        libxrender1 \
        libsm6 \
        curl \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install uv (pinned image, not :latest)
COPY --from=ghcr.io/astral-sh/uv:0.4 /uv /usr/local/bin/uv

ENV UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=1 \
    UV_PYTHON_DOWNLOADS=never \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    LOG_LEVEL=INFO \
    HF_TOKEN=${HF_TOKEN:-}

WORKDIR /app

# 1. Copy deps metadata — cached unless pyproject.toml or uv.lock changes
COPY pyproject.toml README.md ./

# 2. Install deps into venv — cached unless deps change
RUN uv venv /app/.venv \
    && . /app/.venv/bin/activate \
    && uv pip install --no-cache -e .

# 3. Copy source — always busts cache after this line, but deps step above is cached
COPY app ./app

# 4. Copy sample PDF for build-time warm-up (model download + init)
COPY sample_invoice.pdf /tmp/sample_invoice.pdf

# 5. Pre-warm: trigger MinerU model download and pipeline init during build.
#    This bakes the models into the image layer so container startup is instant.
RUN . /app/.venv/bin/activate \
    && python -c " \
        import sys, logging; \
        logging.basicConfig(level=logging.INFO, format='%(message)s'); \
        sys.path.insert(0, '/app'); \
        from app.mineru_extractor import warm_up, convert_pdf_path; \
        from pathlib import Path; \
        print('PRE-WARM: initializing MinerU models...'); \
        warm_up(); \
        print('PRE-WARM: warming with sample PDF...'); \
        result = convert_pdf_path(Path('/tmp/sample_invoice.pdf')); \
        print(f'PRE-WARM: done — pages={result.pages}, is_image_based={result.is_image_based}'); \
    " \
    && rm /tmp/sample_invoice.pdf

EXPOSE 8082

HEALTHCHECK --interval=10s --timeout=3s --start-period=30s --retries=3 \
    CMD curl -fsS http://localhost:8082/health || exit 1

CMD ["/app/.venv/bin/uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8082"]
