@startuml flow-3-sse-stream
title Flow 3 — SSE Result Streaming

skinparam sequenceArrowThickness 2
skinparam roundcorner 8
skinparam sequenceParticipantBackgroundColor #F5F5F5
skinparam sequenceParticipantBorderColor #999999

participant "Client / UI" as C
participant "lc-check-svc" as API
database "PostgreSQL" as DB

C -> API: GET /stream/{sessionId}
API -> API: read Cache (miss → PostgreSQL)
API -->> C: SSE: QUEUED
API -> API: read Cache (miss → PostgreSQL)
API -->> C: SSE: status update
API -->> C: SSE: DONE + report
@enduml
