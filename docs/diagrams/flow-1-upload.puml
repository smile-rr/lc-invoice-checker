@startuml flow-1-upload
title Flow 1 — Task Submission

skinparam sequenceArrowThickness 2
skinparam roundcorner 8
skinparam sequenceParticipantBackgroundColor #F5F5F5
skinparam sequenceParticipantBorderColor #999999

participant "Client / UI" as C
participant "lc-check-svc" as API
participant "S3 (MinIO)" as S3
database "PostgreSQL" as DB

C -> API: POST /api/v1/files/upload (lc + invoice)
API -> API: validate input
API -> S3: store LC text + invoice PDF
S3 -->> API: keys
API -> DB: INSERT session (QUEUED)
DB -->> API: sessionId
API -->> C: 200 { sessionId, status:"QUEUED" }
@enduml
