# MLX LLM server — local config

# Model preset: light | balanced | quality
#   light     → Qwen3-VL-4B-Instruct-4bit (one model, both vision + text)
#   balanced  → Qwen3-VL-8B-Instruct-4bit (one model, both vision + text)
#   quality   → 8B VLM for vision + Qwen3-4B-Instruct for text (serial swap)
LLM_PRESET=light

# Per-instance model override (optional, takes precedence over preset)
VISION_MODEL_OVERRIDE=
TEXT_MODEL_OVERRIDE=

# API server bind
API_HOST=127.0.0.1
API_PORT=8088

# Inference defaults (overridden per-request via OpenAI request body)
MAX_TOKENS_DEFAULT=2048
TEMPERATURE_DEFAULT=0.1

# Always false on -Instruct models. Critical: never enable thinking overhead.
ENABLE_THINKING=false

# Logging
LOG_LEVEL=INFO
