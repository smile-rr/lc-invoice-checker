# LC Invoice Checker — local development environment
#
# Workflow: only Postgres runs in Docker (`docker compose up -d`). The Java
# service runs locally via `./gradlew bootRun` from lc-checker-svc/, and the
# optional Python parsers (docling / mineru) run via their own uvicorn on
# localhost. See module READMEs for details.
#
# Copy this file to `.env` and fill in your API keys. `.env` is git-ignored.

# =============================================================================
# LLM — Language model (Type B / AB rule checks)
# Provider: Qwen Bailian (recommended), DeepSeek, Ollama, any OpenAI-compatible
#
# Local MLX option (zero-network, runs on Apple Silicon — see llm/mlx-server/):
#   LLM_BASE_URL=http://localhost:8088/v1
#   LLM_MODEL=qwen3-vl-4b
#   LLM_API_KEY=local
# Start the server first: `make llm-install` (one-time) then `make llm-up`.
# =============================================================================
LLM_API_KEY=YOUR_QWEN_BAILIAN_KEY
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# Fallback language model (optional)
LLM_FALLBACK_BASE_URL=https://api.minimaxi.chat/v1
LLM_FALLBACK_MODEL=MiniMax-Text-01

# =============================================================================
# Vision LLM — Stage 1b invoice extraction (rendered PDF pages → Vision LLM)
#
# Local MLX option (same server as LLM above — Qwen3-VL handles both roles):
#   VISION_BASE_URL=http://localhost:8088/v1
#   VISION_MODEL=qwen3-vl-4b
#   VISION_API_KEY=local
# =============================================================================
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_API_KEY=YOUR_QWEN_BAILIAN_KEY
VISION_MODEL=qwen-vl-plus
VISION_TEMPERATURE=0.0
VISION_RENDER_SCALE=1.5
VISION_TIMEOUT_SECONDS=120

# =============================================================================
# Stage 1b extractor sources — per-source enable flags
# Two-lane orchestration:
#   Lane A (parallel):   remote_vision  (cloud LLM, no local resources)
#   Lane B (sequential): docling → mineru → local_vision  (all consume local CPU/RAM)
# Disabled sources are HIDDEN from the UI (not greyed) — the backend chain
# only contains enabled ones, so /extracts never includes a disabled source.
# =============================================================================
EXTRACTOR_VISION_ENABLED=true
EXTRACTOR_LOCAL_VISION_ENABLED=false
EXTRACTOR_DOCLING_ENABLED=false
EXTRACTOR_MINERU_ENABLED=false
EXTRACTOR_DOCLING_URL=http://localhost:8081
EXTRACTOR_MINERU_URL=http://localhost:8082
EXTRACTOR_CONFIDENCE_THRESHOLD=0.80

# Local vision LLM (Ollama on this host) — only used when
# EXTRACTOR_LOCAL_VISION_ENABLED=true. Pull a multimodal model first:
#   ollama pull qwen2.5vl   (or any vision-capable model)
LOCAL_VISION_BASE_URL=http://localhost:11434/v1
LOCAL_VISION_API_KEY=
LOCAL_VISION_MODEL=qwen2.5vl
LOCAL_VISION_RENDER_SCALE=1.5
LOCAL_VISION_TIMEOUT_SECONDS=300

# =============================================================================
# Port bindings (host side)
# =============================================================================
API_PORT=8080
POSTGRES_PORT=5432

# =============================================================================
# PostgreSQL 16 — runs in Docker on the host-mapped port
# The Java service (local) reaches it via localhost:5432.
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=lcuser
DB_PASSWORD=lcpass123

# =============================================================================
# Spring profile — default (console logs) or prod (JSON logs)
# =============================================================================
SPRING_PROFILES_ACTIVE=default

# =============================================================================
# Local MLX LLM server (llm/mlx-server) — optional, only used if you point
# LLM_BASE_URL / VISION_BASE_URL at http://localhost:8088/v1 above.
# All MLX_* keys are read by llm/mlx-server's pydantic-settings from this file.
# =============================================================================
MLX_PRESET=light                    # light | balanced | quality
MLX_API_HOST=127.0.0.1
MLX_API_PORT=8088
MLX_MAX_TOKENS_DEFAULT=2048
MLX_TEMPERATURE_DEFAULT=0.1
MLX_ENABLE_THINKING=false
MLX_LOG_LEVEL=INFO

# Override the preset's models (optional; takes precedence over preset)
MLX_VISION_MODEL_OVERRIDE=
MLX_TEXT_MODEL_OVERRIDE=

# HuggingFace token — anonymous downloads from HF are rate-limited and slower.
# Get a read-only token at https://huggingface.co/settings/tokens. Sourced into
# the uvicorn process by `make llm` (the Makefile loads this .env before launch).
HF_TOKEN=

# =============================================================================
# MinerU extractor (extractors/mineru) — pipeline knobs read at uvicorn launch
# =============================================================================
MINERU_TABLE_ENABLED=true       # render markdown tables (line items, totals)
MINERU_FORMULA_ENABLED=true     # render formulas (rare in invoices, cheap)
MINERU_LANG=en                  # comma-separated OCR langs (e.g. "en,ch")
MINERU_MD_MODE=mm               # "mm"=rich markdown w/ tables ; "nlp"=text-stripped
