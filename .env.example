# LC Invoice Checker — local development environment
# Copy this file to `.env` and fill in LLM_API_KEY. `.env` is git-ignored.

# ----- LLM credentials ------------------------------------------------------
# Primary provider (DeepSeek default). Both providers speak OpenAI-compatible
# /v1/chat/completions, so only URL + model + key differ.
LLM_API_KEY=sk-REPLACE_ME
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Fallback (MiniMax). Leave defaults unless swapping providers.
LLM_FALLBACK_BASE_URL=https://api.minimaxi.chat/v1
LLM_FALLBACK_MODEL=MiniMax-Text-01

# ----- Vision LLM extractor (V1.5 primary) ------------------------------------
# Local Ollama (M1 Mac): pull models first — see README-vision.md
VISION_PROVIDER=ollama
VISION_BASE_URL=http://localhost:11434/v1
VISION_MODEL=moondream:2b
VISION_API_KEY=
VISION_TEMPERATURE=0.0
VISION_RENDER_SCALE=1.5
VISION_TIMEOUT_SECONDS=120

# ----- Extractor routing -------------------------------------------------------
# extractor.vision-enabled=true  → vision LLM primary  (default)
# extractor.docling-enabled=true → docling fallback #1 (default)
# extractor.mineru-enabled=false → mineru fallback #2 (V1.5)
EXTRACTOR_VISION_ENABLED=true
EXTRACTOR_DOCLING_ENABLED=true
EXTRACTOR_MINERU_ENABLED=false
# ----- Port bindings (host side) --------------------------------------------
API_PORT=8080
DOCLING_PORT=8081
OLLAMA_PORT=11434
# MINERU_PORT=8082  # V1.5

# ----- Spring profile -------------------------------------------------------
# `default` → console pretty logs for dev.
# `prod`    → JSON logs (logback-json.xml), Actuator hardening.
SPRING_PROFILES_ACTIVE=default

# ----- Extractor sidecar logging -------------------------------------------
DOCLING_LOG_LEVEL=INFO
# MINERU_LOG_LEVEL=INFO
