# LC Invoice Checker — local development environment
#
# Workflow: only Postgres runs in Docker (`docker compose up -d`). The Java
# service runs locally via `./gradlew bootRun` from lc-checker-svc/, and the
# optional Python parsers (docling / mineru) run via their own uvicorn on
# localhost. See module READMEs for details.
#
# Copy this file to `.env` and fill in your API keys. `.env` is git-ignored.

# =============================================================================
# LLM — Language model (Type B / AB rule checks)
# Provider: Qwen Bailian (recommended), DeepSeek, or any OpenAI-compatible API.
# =============================================================================
LLM_API_KEY=YOUR_QWEN_BAILIAN_KEY
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# =============================================================================
# Sidecar LLM (text) — used by docling/mineru's llm_field_extractor.py to
# extract structured fields from raw markdown. Sidecars try these first; if
# unset, fall through to LLM_* (cloud) above; if both unset, regex tier
# fires. Defaults below point at local Ollama so docling/mineru run all-
# local — no DashScope spend on those two lanes.
# =============================================================================
SIDECAR_LLM_BASE_URL=http://127.0.0.1:11434/v1
SIDECAR_LLM_API_KEY=
SIDECAR_LLM_MODEL=qwen3-vl:4b-instruct

# =============================================================================
# Vision LLM — Slots 1–4 (uniform config, source name in DB/UI: <model>_N)
# Slots run in parallel; first SUCCESS in slot order (1→2→3→4) wins selection.
# Slot 1 = local Ollama (no api-key). Slots 2–4 = cloud (set VISION_N_API_KEY).
# Provider switch per slot: change VISION_N_BASE_URL + VISION_N_MODEL.
#
# Ollama setup (slot 1):
#   brew install ollama && ollama serve &
#   ollama pull qwen3-vl:4b-instruct   # use -instruct tag; bare :4b emits <think> tokens
# =============================================================================
VISION_1_ENABLED=true
VISION_1_BASE_URL=http://127.0.0.1:11434/v1
VISION_1_API_KEY=
VISION_1_MODEL=qwen3-vl:4b-instruct
VISION_1_RENDER_DPI=200
VISION_1_MAX_PAGES=10
VISION_1_MAX_LONG_EDGE_PX=2048
VISION_1_TIMEOUT_SECONDS=300

VISION_2_ENABLED=true
VISION_2_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_2_API_KEY=YOUR_BAILIAN_KEY
VISION_2_MODEL=qwen3.6-plus-2026-04-02
VISION_2_RENDER_DPI=200
VISION_2_MAX_PAGES=10
VISION_2_MAX_LONG_EDGE_PX=2048
VISION_2_TIMEOUT_SECONDS=120

VISION_3_ENABLED=false
VISION_3_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_3_API_KEY=YOUR_BAILIAN_KEY
VISION_3_MODEL=qwen3.6-flash
VISION_3_RENDER_DPI=200
VISION_3_MAX_PAGES=10
VISION_3_MAX_LONG_EDGE_PX=2048
VISION_3_TIMEOUT_SECONDS=120

VISION_4_ENABLED=false
VISION_4_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_4_API_KEY=YOUR_BAILIAN_KEY
VISION_4_MODEL=qwen3.6-27b
VISION_4_RENDER_DPI=200
VISION_4_MAX_PAGES=10
VISION_4_MAX_LONG_EDGE_PX=2048
VISION_4_TIMEOUT_SECONDS=120

# =============================================================================
# Extractor confidence + supplementary sources
# =============================================================================
EXTRACTOR_CONFIDENCE_THRESHOLD=0.80
EXTRACTOR_DOCLING_ENABLED=true
EXTRACTOR_MINERU_ENABLED=true

# =============================================================================
# Docling sidecar — text-layout extraction (supplementary source)
# Source name in DB / SSE / UI: docling
# Requires docling-svc running (docker compose --profile full)
# =============================================================================
DOCLING_BASE_URL=http://localhost:8081
DOCLING_TIMEOUT_SECONDS=60

# =============================================================================
# MiniRU sidecar — text-layout extraction (supplementary source)
# Source name in DB / SSE / UI: mineru
# Requires mineru-svc running (docker compose --profile full)
# =============================================================================
MINERU_BASE_URL=http://localhost:8082
MINERU_TIMEOUT_SECONDS=60

# =============================================================================
# Port bindings (host side)
# =============================================================================
API_PORT=8080
POSTGRES_PORT=5432

# =============================================================================
# PostgreSQL 16 — runs in Docker on the host-mapped port
# The Java service (local) reaches it via localhost:5432.
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=lcuser
DB_PASSWORD=lcpass123

# Optional: pin the local source-IP for JDBC sockets to defend against
# NoRouteToHostException on macOS dev machines that run a TUN-based proxy
# (ClashX, Surge, Mihomo, V2RayU). Set to your LAN-facing interface IP, e.g.
# `DB_LOCAL_BIND=192.168.31.201`. Leave empty in normal environments.
DB_LOCAL_BIND=

# =============================================================================
# Spring profile — default (console logs) or prod (JSON logs)
# =============================================================================
SPRING_PROFILES_ACTIVE=default

# =============================================================================
# MinIO — object storage for original LC text + invoice PDFs
# Console: $MINIO_ENDPOINT (port-shifted UI; e.g. http://host:9001)
# Bucket is content-addressed by SHA-256 — re-uploading the same file is a
# free dedup on the second put. Set MINIO_ENABLED=false to run memory-only
# (sessions then won't survive a service restart).
# =============================================================================
MINIO_ENABLED=true
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=lc-pdfs
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=                # MinIO server access key (required)
MINIO_SECRET_KEY=                # MinIO server secret key (required)
MINIO_PATH_STYLE=true            # MinIO needs path-style; true unless you front it with a CDN
MINIO_REQUEST_TIMEOUT_SECONDS=3  # hard ceiling on every put/get; expires fail-soft

# =============================================================================
# MinerU extractor (extractors/mineru) — pipeline knobs read at uvicorn launch
# =============================================================================
MINERU_TABLE_ENABLED=true       # render markdown tables (line items, totals)
MINERU_FORMULA_ENABLED=true     # render formulas (rare in invoices, cheap)
MINERU_LANG=en                  # comma-separated OCR langs (e.g. "en,ch")
MINERU_MD_MODE=mm               # "mm"=rich markdown w/ tables ; "nlp"=text-stripped
